flowchart LR
  %% ===== style (na wzór szkicu) =====
  classDef input  fill:#3a1d00,stroke:#ff9933,stroke-width:2px,color:#ffcc99;
  classDef stage  fill:#161616,stroke:#777,stroke-width:1px,color:#bdbdbd;
  classDef agent  fill:#0b1020,stroke:#2a4a7f,stroke-width:1.5px,color:#a9c2e6;
  classDef merge  fill:#0d1b2e,stroke:#4a90d9,stroke-width:2px,color:#bcd6f5;
  classDef synth  fill:#101a0d,stroke:#5bbf4a,stroke-width:2px,color:#bfe6b3;
  classDef format fill:#220000,stroke:#e63946,stroke-width:2px,color:#ff8a93;

  Q(["1. Input: pytanie researchowe"]):::input

  %% ===== faza 1: front-end skill (wątek główny, interaktywny) =====
  subgraph FE["2. Dobieranie kontekstu — front-end skill (wątek główny)"]
    direction TB
    C1["Subagent Explore:<br/>codebase"]:::agent
    C2["Subagent Explore:<br/>dokumentacja"]:::agent
    C3["CLAUDE.md<br/>(inferencja audience)"]:::agent
    C4["Zadanie:<br/>Jira / Linear MCP"]:::agent
    Mctx{"Merge → Research brief<br/>(goal + scope/depth/recency/<br/>source + audience)"}:::merge
    C1 --> Mctx
    C2 --> Mctx
    C3 --> Mctx
    C4 --> Mctx
  end

  Q --> C1
  Q --> C2
  Q --> C3
  Q --> C4

  %% ===== faza 2: dynamic workflow (subagenty, lekki return) =====
  subgraph WF["Dynamic Workflow — subagenty (do wątku głównego wraca tylko ścieżka + manifest)"]
    direction TB
    Plan["3. Plan: podział na pod-pytania<br/>+ ustalenie zależności"]:::stage

    subgraph ROUND["4. Research round — gate'owana przez Assessor (×N)"]
      direction TB
      subgraph RET["Retrieval — równolegle"]
        direction TB
        R1["Retriever: firecrawl<br/>(WebSearch fallback)"]:::agent
        R2["Retriever: firecrawl"]:::agent
        R3["Retriever: firecrawl"]:::agent
        F1["Findings + evidence spans<br/>+ kandydaci na obrazki [src ids]"]:::agent
        F2["Findings + evidence spans [src ids]"]:::agent
        F3["Findings + evidence spans [src ids]"]:::agent
        R1 --> F1
        R2 --> F2
        R3 --> F3
      end

      Dedup{"Dedup po URL →<br/>append-only numeric ids"}:::merge
      Scout["Conflict-scout: diff findings<br/>→ conflicts[] (material? resolvable?)"]:::agent
      Verify["Verifier (tylko deep brief):<br/>próba obalenia material findings"]:::agent

      F1 --> Dedup
      F2 --> Dedup
      F3 --> Dedup
      Dedup --> Scout
      Scout -. "deep brief" .-> Verify
    end

    Assess{"5. Assessor — jedyna bramka:<br/>pokrycie OK + brak material/<br/>resolvable conflict lub refutation?"}:::merge
    Synth["6. Synthesizer (raz, po green-light):<br/>reconcile findings, ujawnij residual<br/>sprzeczności (z atrybucją), draft answer z [id]"]:::synth
    Edit["7. Editor: tnij lanie wody,<br/>de-jargon pod audience,<br/>oznacz wizualizacje"]:::format
    Comp["8. Composer: HTML report (ToC + [n])<br/>mmdc→SVG (preflight degraduje),<br/>wizualizacje z findings, snapshot + state"]:::format

    Plan --> R1
    Plan --> R2
    Plan --> R3
    Scout --> Assess
    Verify -. "deep brief" .-> Assess
    Assess -->|"kolejna runda<br/>(cap rund + budżet)"| Plan
    Assess -->|"pokrycie OK"| Synth
    Synth --> Edit
    Edit --> Comp
  end

  Mctx --> Plan

  %% ===== faza 3: prezentacja + checkpoint człowieka =====
  Comp --> Pres(["9. Prezentacja: manifest inline<br/>+ ścieżka + oferta otwarcia"]):::stage
  Pres --> Human{"Follow-up?"}:::merge
  Human -->|"user wybiera/dodaje pytania → nowy run<br/>rozszerza TEN SAM ewoluujący Report<br/>(Synthesizer re-synth całości, ids append-only)"| Plan
  Human -->|"koniec"| Done(["Koniec"]):::input
