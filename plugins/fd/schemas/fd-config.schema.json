{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grixu.dev/cc-toolkit/fd/schemas/fd-config.schema.json",
  "title": "fd-config.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "language", "storage", "tooling", "mcp", "codeReview", "tasks", "implement", "prs", "validation", "detectedAt"],
  "properties": {
    "schema": { "type": "integer", "const": 1 },
    "language": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default"],
      "properties": {
        "default": { "type": "string" }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "featuresRoot"],
      "properties": {
        "mode": { "type": "string", "enum": ["per-feature", "shared"] },
        "featuresRoot": { "type": "string" },
        "shared": {
          "type": "object",
          "additionalProperties": false,
          "required": ["contextMode"],
          "properties": {
            "contextMode": { "type": "string", "enum": ["per-app", "per-bounded-context"] },
            "contextFile": { "type": "string" },
            "boundedContextsFile": { "type": "string" },
            "adrRoot": { "type": "string" },
            "specsRoot": { "type": "string" }
          }
        },
        "docs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["contextMode"],
          "properties": {
            "contextMode": { "type": "string", "enum": ["per-feature", "per-app", "per-bounded-context"] },
            "contextFile": { "type": "string" },
            "adrRoot": { "type": "string" },
            "boundedContextsFile": { "type": "string" }
          }
        }
      }
    },
    "tooling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageManager", "build", "lint", "test", "format"],
      "properties": {
        "packageManager": { "type": ["string", "null"] },
        "build": { "type": ["string", "null"] },
        "lint": { "type": ["string", "null"] },
        "test": { "type": ["string", "null"] },
        "format": { "type": ["string", "null"] }
      }
    },
    "mcp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["detected"],
      "properties": {
        "detected": { "type": "array", "items": { "type": "string" } }
      }
    },
    "codeReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skills"],
      "properties": {
        "skills": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "tasks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxContextTokens", "charsPerToken", "maxElements", "maxAcceptanceCriteria", "granularityBias"],
      "properties": {
        "maxContextTokens": { "type": "integer", "minimum": 1 },
        "charsPerToken": { "type": "number", "minimum": 1 },
        "maxElements": { "type": ["integer", "null"], "minimum": 1 },
        "maxAcceptanceCriteria": { "type": ["integer", "null"], "minimum": 1 },
        "granularityBias": { "type": "string" }
      }
    },
    "implement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branchTemplate", "maxRepairIterations", "engine", "worktreeSetup", "worktreeCleanup"],
      "properties": {
        "branchTemplate": { "type": "string" },
        "maxRepairIterations": { "type": "integer", "minimum": 1 },
        "engine": { "type": "string", "enum": ["workflow", "subagents"] },
        "ciScope": { "type": "string", "enum": ["full", "scoped"] },
        "worktreeSetup": { "type": "array", "items": { "type": "string" } },
        "worktreeCleanup": { "type": "string", "enum": ["always", "keep-failed"] }
      }
    },
    "prs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "grouping", "baseBranch", "verifyPerPrCi"],
      "properties": {
        "model": { "type": "string" },
        "grouping": { "type": "string" },
        "baseBranch": { "type": "string" },
        "verifyPerPrCi": { "type": "boolean" }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowWaiver", "dimensions"],
      "properties": {
        "allowWaiver": { "type": "boolean" },
        "dimensions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["spec", "tasks"],
          "properties": {
            "spec": { "type": "array", "items": { "type": "string" } },
            "tasks": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "detectedAt": { "type": "string" }
  }
}
